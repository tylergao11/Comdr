{
  "name": "@comdr/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent 1 — 全系统共享类型 + 配置 + 日志",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "default": "./dist/contracts.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "smol-toml": "^1.6.1"
  }
}
