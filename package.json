{
  "name": "comdr",
  "version": "0.1.0",
  "private": true,
  "description": "通用 Coding Agent — TypeScript 编排层 + Rust 执行层",
  "scripts": {
    "build": "tsc -b",
    "build:tools": "cd crates/comdr-tools && cargo build --release && napi artifacts",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "lint": "eslint packages/ --ext .ts",
    "link": "pnpm build && node scripts/install-global.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
