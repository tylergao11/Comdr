{
  "name": "comdr",
  "version": "0.1.0",
  "private": true,
  "description": "通用 Coding Agent — TypeScript 编排层 + Rust 执行层",
  "scripts": {
    "build": "tsc -b",
    "build:tools": "cd crates/comdr-tools && cargo build --release && napi artifacts",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "lint": "eslint packages/ --ext .ts",
    "test": "npx tsx tests/integration.test.ts && npx tsx tests/rag.test.ts",
    "test:rag": "npx tsx tests/rag.test.ts",
    "test:integration": "npx tsx tests/integration.test.ts",
    "link": "pnpm build && node scripts/install-global.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
